#!/usr/bin/env python3
from sys import argv

def factorize(number):
    """
    """
    if number  == 2:
        return number, 1
    else :
        for factor in range(3, int(number ** 0.5) + 1, 2):
            if number  == (factor * (number // factor)):
                return number // factor, factor
        return None

def main():
    """
    """
    if len(argv) != 2:
        print("Usage: rsa <file>")
        return 1

    filename = argv[1]
    with open(filename, 'r') as file:
        for line in file:
            number = int(line.strip())
            factors_pairs = factorize(number)
            if factors_pairs == None:
                print(f"{number} is not a semi-prime number")
            else:
                print(f"{number}={factors_pairs[0]}*{factors_pairs[1]}")
if __name__ == "__main__":
    main()

